@using GameZone.Settings

@model GameZone.ViewModels.CreateGameFormViewModel
@{
	ViewData["Title"] = "Add Game";
}
<h5>
	<i class="bi bi-plus-circle-dotted"></i>
	Add a New Game

</h5>
<form asp-controller="Games" enctype="multipart/form-data" asp-action="Create">
	<div class="row">
		<div class="col-md-6">
			<div class="form-group">
				<label asp-for="Name" class="form-label mt-4"></label>
				<input type="text" class="form-control" asp-for="Name" placeholder="Name">
				<span asp-validation-for="Name" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="CategoryId" class="form-label mt-4"></label>
				<select class="form-select" asp-for=CategoryId asp-items="Model.Categories"
				data-placeholder="Select a Category" data-minimum-results-for-search="Infinity">
					<option value=""></option>
				</select>
				<span asp-validation-for="CategoryId" class="text-danger"></span>
		    </div>

				<div class="form-group">
					<label asp-for="SelectDevices" class="form-label mt-4"></label>
				    <select class="form-select" asp-for=SelectDevices asp-items="Model.Devices"
						data-placeholder="Select Device">
						<option></option>
					</select>
					<span asp-validation-for="SelectDevices" class="text-danger"></span>
			    </div>

			    <div class="form-group">
				  <label asp-for="Description" class="form-label mt-4"></label>
				  <textarea asp-for="Description" class="form-control" placeholder="Description"></textarea>
				  <span asp-validation-for="Description" class="text-danger"></span>
			    </div>

			    <div class="form-group">
				  <label asp-for="Cover" class="form-label mt-4"></label>
				  <input type="file" class="form-control" asp-for="Cover" />
				  
				<span asp-validation-for="Cover" class="text-danger d-block"></span>
				<small class="form-text text-muted">Only .jpg, .jpeg, .png files are allowed with max size 2MB</small>
			    </div>
			<button  type="Submit" class="btn btn-light text-black mt-4">Save</button>
		</div>
		<div class="col-md-6  d-flex justify-content-center pt-5 overflow-hidden">
			<img class="cover-preview d-none" alt="Cover"  />

			</div>
			
    </div>


</form>
@section Scripts {
	<partial name="_ValidationScriptsPartial" />
	<script>
				$(document).ready(function(){
					$('#Cover').on('change', function(){
						$('.cover-preview').attr('src', window.URL.createObjectURL(this.files[0])).removeClass('d-none');
			});
		});
	</script>
}
